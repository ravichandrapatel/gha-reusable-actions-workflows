#!/usr/bin/env bash
# =============================================================================
# FILE_NAME: commit-msg
# DESCRIPTION: Repo-local hook sample — delegates to global hook orchestrator in policies/.
# VERSION: 1.1.0
# EXIT_CODES/SIGNALS: Delegates to policies/scripts/global_hooks/commit-msg
# AUTHORS: DevOps Team
# =============================================================================
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
exec bash "${REPO_ROOT}/policies/scripts/global_hooks/commit-msg" "$@"
