#!/usr/bin/env bash
# =============================================================================
# FILE_NAME: pre-commit
# DESCRIPTION: Git pre-commit hook — SPVS security scans for staged files.
# VERSION: 1.0.0
# EXIT_CODES/SIGNALS: 0 pass, non-zero on scan failure
# AUTHORS: DevOps Team
# =============================================================================
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "${REPO_ROOT}"

if [[ -f "${REPO_ROOT}/.env" ]]; then
  # shellcheck disable=SC1091
  source "${REPO_ROOT}/.env"
fi

mapfile -d '' -t STAGED_FILES < <(git diff --cached --name-only -z --diff-filter=ACMR)
if [[ ${#STAGED_FILES[@]} -eq 0 ]]; then
  exit 0
fi

exec bash "${REPO_ROOT}/policies/scripts/pre_commit_spvs_wrapper.sh" "${STAGED_FILES[@]}"
