# Local brain snapshots from `okf.py snapshot` (do not commit)
_okf_knowledge/.okf-snapshots/

# kustomize helmCharts pull cache (any path / version)
**/charts/
**/Chart.lock
**/*.tgz

# act-platform secrets (do not commit)
.secrets
.vars
.act/.secrets
.act/.vars
