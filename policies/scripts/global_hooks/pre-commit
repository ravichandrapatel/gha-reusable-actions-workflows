#!/usr/bin/env bash
# =============================================================================
# FILE_NAME: pre-commit
# DESCRIPTION: Global git pre-commit hook — shell-only SPVS + Terraform checks.
# VERSION: 1.1.0
# EXIT_CODES/SIGNALS: 0 pass, non-zero on scan failure
# AUTHORS: DevOps Team
# =============================================================================
# SPVS-GLOBAL-HOOK: installed by policies/scripts/install_dev_hooks.sh
set -euo pipefail

PROJECT_PREFIX="[SPVS-GLOBAL-PRE-COMMIT]"
HOOKS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

_log() {
  [[ "${SPVS_HOOK_VERBOSE:-0}" == "1" ]] || return 0
  printf '%s %s\n' "${PROJECT_PREFIX}" "$*" >&2
}

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${REPO_ROOT}" ]]; then
  exit 0
fi

cd "${REPO_ROOT}"

if [[ -f "${REPO_ROOT}/.env" ]]; then
  # shellcheck disable=SC1091
  source "${REPO_ROOT}/.env"
fi

mapfile -d '' -t STAGED_FILES < <(git diff --cached --name-only -z --diff-filter=ACMR)
if [[ ${#STAGED_FILES[@]} -eq 0 ]]; then
  exit 0
fi

if [[ -x "${HOOKS_DIR}/run_terraform_hooks.sh" ]]; then
  _log "[DBG-000] Running Terraform shell hooks"
  bash "${HOOKS_DIR}/run_terraform_hooks.sh"
fi

WRAPPER="${REPO_ROOT}/policies/scripts/pre_commit_spvs_wrapper.sh"
if [[ -f "${WRAPPER}" ]]; then
  _log "[DBG-001] Running SPVS shell hooks"
  exec bash "${WRAPPER}" "${STAGED_FILES[@]}"
fi

_log "[DBG-002] No SPVS wrapper in repo; Terraform-only pass"
exit 0
